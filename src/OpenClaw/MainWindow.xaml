<Window
    x:Class="OpenClaw.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClaw"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenClaw">

    <Grid x:Name="RootLayout"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="37" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Height="37"
              Margin="0,-1,0,0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftInsetColumn" Width="0" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightInsetColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <Image Width="16"
                       Height="16"
                       Source="Assets/apple-touch-icon.png" />
                <TextBlock Text="OpenClaw"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>

            <Grid x:Name="TitleBarDragRegion"
                  Grid.Column="2"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch" />
        </Grid>

        <Grid Grid.Row="1"
              Padding="12,8"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8">
                <ComboBox x:Name="EnvironmentSelector"
                          MinWidth="160"
                          ItemsSource="{x:Bind ViewModel.Environments}"
                          SelectedItem="{x:Bind ViewModel.SelectedEnvironment, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Select environment" />

                <TextBlock x:Name="UrlDisplay"
                           Margin="8,0,0,0"
                           MaxWidth="400"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextSelectionEnabled="True"
                           Text="{x:Bind ViewModel.CurrentUrl, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel x:Name="TitleBarActions"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4">
                <Border x:Name="ThemeSwitcherContainer"
                        Padding="2"
                        Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel Orientation="Horizontal"
                                Spacing="2">
                        <Button x:Name="SystemThemeButton"
                                Tag="System"
                                Click="OnThemeSelectionClick"
                                ToolTipService.ToolTip="System theme"
                                Style="{StaticResource ThemeSegmentButtonStyle}">
                            <FontIcon Glyph="&#xE7F4;" FontSize="13" />
                        </Button>

                        <Button x:Name="LightThemeButton"
                                Tag="Light"
                                Click="OnThemeSelectionClick"
                                ToolTipService.ToolTip="Light theme"
                                Style="{StaticResource ThemeSegmentButtonStyle}">
                            <FontIcon Glyph="&#xE706;" FontSize="13" />
                        </Button>

                        <Button x:Name="DarkThemeButton"
                                Tag="Dark"
                                Click="OnThemeSelectionClick"
                                ToolTipService.ToolTip="Dark theme"
                                Style="{StaticResource ThemeSegmentButtonStyle}">
                            <FontIcon Glyph="&#xE708;" FontSize="13" />
                        </Button>
                    </StackPanel>
                </Border>

                <Button x:Name="SettingsButton"
                        Click="OnSettingsClick"
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>

                <Button x:Name="AboutButton"
                        Click="OnAboutClick"
                        ToolTipService.ToolTip="About"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ConnectionInfoBar"
                 Grid.Row="2"
                 IsOpen="{x:Bind ViewModel.IsErrorVisible, Mode=OneWay}"
                 Severity="Error"
                 Title="Connection Issue"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="True"
                 Closed="OnInfoBarClosed">
            <InfoBar.ActionButton>
                <Button Content="Retry"
                        Command="{x:Bind ViewModel.RetryCommand}"
                        Visibility="{x:Bind ViewModel.RetryButtonVisibility, Mode=OneWay}"
                        HorizontalAlignment="Right" />
            </InfoBar.ActionButton>
        </InfoBar>

        <InfoBar x:Name="DiagnosticInfoBar"
                 Grid.Row="3"
                 IsOpen="{x:Bind ViewModel.IsDiagnosticVisible, Mode=OneWay}"
                 Severity="Informational"
                 Title="Diagnostics"
                 Message="{x:Bind ViewModel.DiagnosticSummary, Mode=OneWay}"
                 IsClosable="True"
                 Closed="OnDiagnosticInfoBarClosed" />

        <Grid Grid.Row="4">
            <WebView2 x:Name="MainWebView" />

            <ProgressRing x:Name="LoadingRing"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="5"
              Padding="12,6"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6">
                <Ellipse x:Name="StatusDot"
                         Width="8"
                         Height="8"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
            </StackPanel>

            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ViewModel.SelectedEnvironmentName, Mode=OneWay}" />
        </Grid>

        <Border x:Name="TopEdgeCover"
                Grid.RowSpan="6"
                Height="1"
                VerticalAlignment="Top"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                IsHitTestVisible="False" />
    </Grid>
</Window>
