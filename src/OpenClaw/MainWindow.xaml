<Window
    x:Class="OpenClaw.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClaw"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="OpenClaw">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Bar -->
            <RowDefinition Height="Auto" />
            <!-- Connection Error InfoBar -->
            <RowDefinition Height="Auto" />
            <!-- Diagnostic InfoBar -->
            <RowDefinition Height="Auto" />
            <!-- WebView2 Main Area -->
            <RowDefinition Height="*" />
            <!-- Status Bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- TOP BAR — Environment selector, URL, and action buttons      -->
        <!-- ============================================================ -->
        <Grid Grid.Row="0" Padding="12,8" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Environment Selector -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <ComboBox x:Name="EnvironmentSelector"
                          MinWidth="160"
                          ItemsSource="{x:Bind ViewModel.Environments}"
                          SelectedItem="{x:Bind ViewModel.SelectedEnvironment, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Select environment" />

                <!-- Current URL display -->
                <TextBlock x:Name="UrlDisplay"
                           Text="{x:Bind ViewModel.CurrentUrl, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           IsTextSelectionEnabled="True"
                           MaxWidth="400"
                           TextTrimming="CharacterEllipsis"
                           Margin="8,0,0,0" />
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <!-- Reload (F5) -->
                <Button x:Name="ReloadButton"
                        Command="{x:Bind ViewModel.ReloadCommand}"
                        ToolTipService.ToolTip="Reload (F5)"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Stop (Escape) -->
                <Button x:Name="StopButton"
                        Command="{x:Bind ViewModel.StopCommand}"
                        ToolTipService.ToolTip="Stop (Esc)"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape" />
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Quick Commands dropdown -->
                <DropDownButton x:Name="QuickCommandsButton"
                                ToolTipService.ToolTip="Quick Commands"
                                Style="{StaticResource SubtleDropDownButtonStyle}">
                    <FontIcon Glyph="&#xE756;" FontSize="14" />
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="/stop — Stop generation"
                                            Command="{x:Bind ViewModel.QuickStopCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE71A;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="/status — Check status"
                                            Command="{x:Bind ViewModel.QuickStatusCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE946;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="/new — New conversation"
                                            Command="{x:Bind ViewModel.QuickNewCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE710;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="/queue — Queue interrupt"
                                            Command="{x:Bind ViewModel.QuickQueueCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8FD;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!-- Separator -->
                <AppBarSeparator />

                <!-- Paste Image (Ctrl+Shift+V) -->
                <Button x:Name="PasteButton"
                        Command="{x:Bind ViewModel.PasteImageCommand}"
                        ToolTipService.ToolTip="Paste Image (Ctrl+Shift+V)"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE77F;" FontSize="14" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="V" Modifiers="Control,Shift" />
                    </Button.KeyboardAccelerators>
                </Button>

                <!-- Open in Browser -->
                <Button x:Name="OpenInBrowserButton"
                        Command="{x:Bind ViewModel.OpenInBrowserCommand}"
                        ToolTipService.ToolTip="Open in Browser"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE774;" FontSize="14" />
                </Button>

                <!-- Separator -->
                <AppBarSeparator />

                <!-- Theme Switcher -->
                <DropDownButton x:Name="ThemeButton"
                                ToolTipService.ToolTip="App Theme"
                                Style="{StaticResource SubtleDropDownButtonStyle}">
                    <FontIcon x:Name="ThemeIcon" Glyph="&#xE7F4;" FontSize="14" />
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Light" Click="OnThemeSelected" Tag="Light">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE706;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Dark" Click="OnThemeSelected" Tag="Dark">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE708;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="System Default" Click="OnThemeSelected" Tag="System">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7F4;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <!-- Settings -->
                <Button x:Name="SettingsButton"
                        Click="OnSettingsClick"
                        ToolTipService.ToolTip="Settings"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>

                <!-- About -->
                <Button x:Name="AboutButton"
                        Click="OnAboutClick"
                        ToolTipService.ToolTip="About"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ============================================================ -->
        <!-- CONNECTION ERROR INFOBAR                                     -->
        <!-- ============================================================ -->
        <InfoBar x:Name="ConnectionInfoBar"
                 Grid.Row="1"
                 IsOpen="{x:Bind ViewModel.IsErrorVisible, Mode=OneWay}"
                 Severity="Error"
                 Title="Connection Issue"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 IsClosable="True"
                 Closed="OnInfoBarClosed">
            <InfoBar.ActionButton>
                <Button Content="Retry"
                        Command="{x:Bind ViewModel.RetryCommand}"
                        Visibility="{x:Bind ViewModel.ShowRetryButton, Mode=OneWay}"
                        HorizontalAlignment="Right" />
            </InfoBar.ActionButton>
        </InfoBar>

        <!-- ============================================================ -->
        <!-- DIAGNOSTICS INFOBAR                                          -->
        <!-- ============================================================ -->
        <InfoBar x:Name="DiagnosticInfoBar"
                 Grid.Row="2"
                 IsOpen="{x:Bind ViewModel.IsDiagnosticVisible, Mode=OneWay}"
                 Severity="Informational"
                 Title="Diagnostics"
                 Message="{x:Bind ViewModel.DiagnosticSummary, Mode=OneWay}"
                 IsClosable="True"
                 Closed="OnDiagnosticInfoBarClosed" />

        <!-- ============================================================ -->
        <!-- MAIN AREA — WebView2 hosting remote OpenClaw UI              -->
        <!-- ============================================================ -->
        <Grid Grid.Row="3">
            <WebView2 x:Name="MainWebView" />

            <!-- Loading overlay -->
            <ProgressRing x:Name="LoadingRing"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Width="48" Height="48"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </Grid>

        <!-- ============================================================ -->
        <!-- STATUS BAR — Connection state, environment, loading          -->
        <!-- ============================================================ -->
        <Grid Grid.Row="4" Padding="12,6"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Connection state indicator -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </StackPanel>

            <!-- Current environment name -->
            <TextBlock Grid.Column="2"
                       Text="{x:Bind ViewModel.SelectedEnvironment.Name, Mode=OneWay, FallbackValue=''}"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
    </Grid>
</Window>
