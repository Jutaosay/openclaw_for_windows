<ContentDialog
    x:Class="OpenClaw.Views.LogViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:OpenClaw.Helpers"
    Title="{x:Bind helpers:StringResources.LogsTitle}"
    PrimaryButtonText="{x:Bind helpers:StringResources.Close}"
    DefaultButton="Primary"
    FullSizeDesired="True">

    <Grid MinWidth="600" MinHeight="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button x:Name="RefreshButton" Click="OnRefresh" ToolTipService.ToolTip="{x:Bind helpers:StringResources.RefreshLogs}">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <Button x:Name="OpenFolderButton" Click="OnOpenLogFolder" ToolTipService.ToolTip="{x:Bind helpers:StringResources.OpenLogFolder}">
                <FontIcon Glyph="&#xE838;" FontSize="14" />
            </Button>
            <TextBlock x:Name="LogFileLabel"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" />
        </StackPanel>

        <!-- Log content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollMode="Auto"
                      HorizontalScrollMode="Auto"
                      VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="LogContent"
                       TextWrapping="NoWrap"
                       FontFamily="Cascadia Mono, Consolas, Courier New"
                       FontSize="12"
                       IsTextSelectionEnabled="True" />
        </ScrollViewer>
    </Grid>
</ContentDialog>
