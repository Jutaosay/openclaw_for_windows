<ContentDialog
    x:Class="OpenClaw.Views.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:OpenClaw.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind helpers:StringResources.AboutTitle}"
    CloseButtonText="{x:Bind helpers:StringResources.Close}"
    DefaultButton="Close">

    <StackPanel MinWidth="360" Padding="0,8" Spacing="16">
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="12">
            <Image Source="/Assets/apple-touch-icon.png" Width="48" Height="48" />
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="OpenClaw"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>

        <Border Height="1"
                Margin="0,4"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <TextBlock Text="{x:Bind helpers:StringResources.AboutDescription}"
                   FontSize="13"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />

        <HyperlinkButton Content="{x:Bind helpers:StringResources.AboutRepository}"
                         HorizontalAlignment="Center"
                         NavigateUri="https://github.com/Jutaosay/openclaw_for_windows" />

        <TextBlock HorizontalAlignment="Center"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
            <Run Text="{x:Bind helpers:StringResources.AboutDevelopedBy}" />
            <Hyperlink NavigateUri="https://github.com/Jutaosay">@Jutaosay</Hyperlink>
        </TextBlock>

        <TextBlock Text="{x:Bind helpers:StringResources.AboutCopyright}"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   HorizontalAlignment="Center" />
    </StackPanel>
</ContentDialog>
