<ContentDialog
    x:Class="OpenClaw.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnSaveClick">

    <Grid MinWidth="500" MinHeight="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Gateway Environments"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Manage your OpenClaw Gateway connections."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="13" />
        </StackPanel>

        <!-- Environment List + Edit Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Environment list -->
            <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListView x:Name="EnvironmentList"
                              Grid.Row="0"
                              SelectionMode="Single"
                              SelectionChanged="OnEnvironmentSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" 
                                Spacing="4" Padding="4"
                                HorizontalAlignment="Center">
                        <Button x:Name="AddButton" Click="OnAddClick"
                                ToolTipService.ToolTip="Add environment">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                        </Button>
                        <Button x:Name="RemoveButton" Click="OnRemoveClick"
                                ToolTipService.ToolTip="Remove environment">
                            <FontIcon Glyph="&#xE738;" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Edit panel -->
            <StackPanel Grid.Column="1" Spacing="12" Padding="8,0,0,0">
                <TextBox x:Name="NameTextBox"
                         Header="Environment Name"
                         PlaceholderText="e.g. Production"
                         Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox x:Name="UrlTextBox"
                         Header="Gateway URL"
                         PlaceholderText="https://your-gateway.example.com"
                         Text="{x:Bind ViewModel.EditUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox x:Name="DefaultCheckBox"
                          Content="Set as default"
                          IsChecked="{x:Bind ViewModel.EditIsDefault, Mode=TwoWay}" />

                <Button Content="Apply"
                        Click="OnApplyClick"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </Grid>

        <!-- Developer Tools section -->
        <Border Grid.Row="2"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="4"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                Margin="0,16,0,0">
            <StackPanel Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                    <TextBlock Text="Developer Tools" FontWeight="SemiBold" />
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Run Diagnostics -->
                    <Button Grid.Row="0" Grid.Column="0"
                            HorizontalAlignment="Stretch" Margin="0,0,4,4"
                            Click="OnRunDiagnosticsClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                            <TextBlock Text="Run Diagnostics" />
                        </StackPanel>
                    </Button>

                    <!-- View Logs -->
                    <Button Grid.Row="0" Grid.Column="1"
                            HorizontalAlignment="Stretch" Margin="4,0,0,4"
                            Click="OnViewLogsClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7BA;" FontSize="14" />
                            <TextBlock Text="View Logs" />
                        </StackPanel>
                    </Button>

                    <!-- DevTools -->
                    <Button Grid.Row="1" Grid.Column="0"
                            HorizontalAlignment="Stretch" Margin="0,4,4,0"
                            Click="OnDevToolsClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEC7A;" FontSize="14" />
                            <TextBlock Text="Open DevTools" />
                        </StackPanel>
                    </Button>

                    <!-- Clear Session -->
                    <Button Grid.Row="1" Grid.Column="1"
                            HorizontalAlignment="Stretch" Margin="4,4,0,0"
                            Click="OnClearSessionClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            <TextBlock Text="Clear Session" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Footer info -->
        <InfoBar Grid.Row="3"
                 x:Name="ValidationInfoBar"
                 IsOpen="False"
                 Severity="Error"
                 Title="Validation Error"
                 Message="All environments must have a name and URL."
                 Margin="0,12,0,0" />
    </Grid>
</ContentDialog>
