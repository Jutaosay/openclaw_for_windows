<Window
    x:Class="OpenClaw.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:OpenClaw.Helpers"
    xmlns:models="using:OpenClaw.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="{x:Bind helpers:StringResources.SettingsTitle}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main content -->
            <RowDefinition Height="*" />
            <!-- Bottom button bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========================================================== -->
        <!-- MAIN CONTENT — Sidebar + Panels                             -->
        <!-- =========================================================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <ListView x:Name="NavList"
                          SelectionMode="Single"
                          SelectionChanged="OnNavSelectionChanged"
                          Padding="4,12">
                    <ListViewItem x:Name="NavLanguage" Tag="Language">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsNavLanguage}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavEnvironments" Tag="Environments">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE909;" FontSize="14" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsNavEnvironments}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavSessions" Tag="Sessions">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsNavSessions}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavDevTools" Tag="DevTools">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsNavDevTools}" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </Border>

            <!-- RIGHT CONTENT -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,20">
                <Grid>
                    <!-- ======= Panel: Language ======= -->
                    <StackPanel x:Name="PanelLanguage" Spacing="12" Visibility="Visible">
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsNavLanguage}"
                                    Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsLanguageDescription}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="13" />

                        <ComboBox x:Name="LanguageComboBox"
                                  SelectionChanged="OnLanguageSelectionChanged"
                                  MinWidth="220"
                                  Margin="0,8,0,0">
                            <ComboBoxItem Content="{x:Bind helpers:StringResources.SettingsLanguageSystem}" Tag="System" />
                            <ComboBoxItem Content="{x:Bind helpers:StringResources.SettingsLanguageEnglish}" Tag="en-US" />
                            <ComboBoxItem Content="{x:Bind helpers:StringResources.SettingsLanguageChineseSimplified}" Tag="zh-CN" />
                        </ComboBox>
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsLanguageRestartHint}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontSize="12"
                                    FontStyle="Italic" />
                    </StackPanel>

                    <!-- ======= Panel: Environments ======= -->
                    <StackPanel x:Name="PanelEnvironments" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsEnvironmentsTitle}"
                                    Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsEnvironmentsDescription}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                     FontSize="13" />

                        <!-- Environment list -->
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="4"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ListView x:Name="EnvironmentList"
                                          Grid.Column="0"
                                          MinHeight="48"
                                          MaxHeight="150"
                                          SelectionMode="Single"
                                          SelectionChanged="OnEnvironmentSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="13" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel Grid.Column="1" Orientation="Vertical"
                                            Spacing="2" Padding="4"
                                            VerticalAlignment="Top">
                                    <Button Click="OnAddClick"
                                            ToolTipService.ToolTip="{x:Bind helpers:StringResources.SettingsAddTooltip}" Padding="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" />
                                    </Button>
                                    <Button Click="OnRemoveClick"
                                            ToolTipService.ToolTip="{x:Bind helpers:StringResources.SettingsRemoveTooltip}" Padding="6">
                                        <FontIcon Glyph="&#xE738;" FontSize="11" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Edit form -->
                        <TextBox x:Name="NameTextBox"
                                 Header="{x:Bind helpers:StringResources.EnvironmentName}"
                                 PlaceholderText="{x:Bind helpers:StringResources.SettingsEnvironmentPlaceholder}"
                                 Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox x:Name="UrlTextBox"
                                 Header="{x:Bind helpers:StringResources.SettingsControlUiUrl}"
                                 PlaceholderText="https://your-gateway.example.com"
                                 Text="{x:Bind ViewModel.EditUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsControlUiUrlHint1}"
                                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                     FontSize="12"
                                     TextWrapping="Wrap" />

                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsControlUiUrlHint2}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="Wrap" />

                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsControlUiUrlHint3}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="Wrap" />

                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsControlUiUrlHint4}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="DefaultCheckBox"
                                      Content="{x:Bind helpers:StringResources.SetAsDefault}"
                                      IsChecked="{x:Bind ViewModel.EditIsDefault, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <Button Content="{x:Bind helpers:StringResources.SettingsApply}"
                                     Click="OnApplyClick"
                                     Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>

                        <InfoBar x:Name="ValidationInfoBar"
                                 IsOpen="False"
                                 Severity="Error"
                                 Title="{x:Bind helpers:StringResources.SettingsValidationError}"
                                 Message="{x:Bind ViewModel.ValidationMessage, Mode=OneWay}" />
                    </StackPanel>

                    <!-- ======= Panel: Sessions ======= -->
                    <StackPanel x:Name="PanelSessions" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsSessionsTitle}"
                                    Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsSessionsDescription}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="13"
                                    TextWrapping="Wrap" />

                        <InfoBar x:Name="SessionInfoBar"
                                  IsOpen="False"
                                  Severity="Informational"
                                  Title="{x:Bind helpers:StringResources.SettingsSessionReset}" />

                        <ListView x:Name="SessionEnvironmentList"
                                  ItemsSource="{x:Bind ViewModel.Environments}"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:EnvironmentConfig">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind GatewayUrl}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="{x:Bind helpers:StringResources.SettingsClearSessionAction}"
                                                Tag="{x:Bind Name}"
                                                Click="OnClearEnvironmentSessionClick"
                                                Margin="12,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- ======= Panel: Developer Tools ======= -->
                    <StackPanel x:Name="PanelDevTools" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsDevToolsTitle}"
                                    Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsDevToolsDescription}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="13" />

                        <CheckBox Content="{x:Bind helpers:StringResources.SettingsEnableDevLog}"
                                  IsChecked="{x:Bind ViewModel.EnableDevLog, Mode=TwoWay}"
                                  Margin="0,4,0,0" />
                        <TextBlock Text="{x:Bind helpers:StringResources.SettingsEnableDevLogDescription}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    TextWrapping="Wrap" />

                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Button HorizontalAlignment="Stretch" Click="OnRunDiagnosticsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                    <TextBlock Text="{x:Bind helpers:StringResources.SettingsRunDiagnostics}" />
                                </StackPanel>
                            </Button>
                            <Button HorizontalAlignment="Stretch" Click="OnViewLogsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" />
                                    <TextBlock Text="{x:Bind helpers:StringResources.SettingsViewLogs}" />
                                </StackPanel>
                            </Button>
                            <Button HorizontalAlignment="Stretch" Click="OnDevToolsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEC7A;" FontSize="14" />
                                    <TextBlock Text="{x:Bind helpers:StringResources.SettingsOpenDevTools}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- =========================================================== -->
        <!-- BOTTOM BUTTON BAR                                           -->
        <!-- =========================================================== -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="{x:Bind helpers:StringResources.Save}"
                        Click="OnSaveClick"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="80" />
                <Button Content="{x:Bind helpers:StringResources.Cancel}"
                        Click="OnCancelClick"
                        MinWidth="80" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
