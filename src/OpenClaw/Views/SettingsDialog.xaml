<Window
    x:Class="OpenClaw.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main content -->
            <RowDefinition Height="*" />
            <!-- Bottom button bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========================================================== -->
        <!-- MAIN CONTENT — Sidebar + Panels                             -->
        <!-- =========================================================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <ListView x:Name="NavList"
                          SelectionMode="Single"
                          SelectionChanged="OnNavSelectionChanged"
                          Padding="4,12">
                    <ListViewItem x:Name="NavAppearance" Tag="Appearance">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE790;" FontSize="14" />
                            <TextBlock Text="Appearance" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavLanguage" Tag="Language">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                            <TextBlock Text="Language" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavEnvironments" Tag="Environments">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE909;" FontSize="14" />
                            <TextBlock Text="Environments" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem x:Name="NavDevTools" Tag="DevTools">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                            <TextBlock Text="Dev Tools" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </Border>

            <!-- RIGHT CONTENT -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,20">
                <Grid>
                    <!-- ======= Panel: Appearance ======= -->
                    <StackPanel x:Name="PanelAppearance" Spacing="12" Visibility="Visible">
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Choose how OpenClaw looks."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />

                        <RadioButtons x:Name="ThemeRadioButtons"
                                      Header="App Theme"
                                      Margin="0,8,0,0"
                                      SelectionChanged="OnThemeRadioSelectionChanged">
                            <RadioButton Tag="Light">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE706;" FontSize="14" />
                                    <TextBlock Text="Light" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Tag="Dark">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE708;" FontSize="14" />
                                    <TextBlock Text="Dark" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Tag="System">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="14" />
                                    <TextBlock Text="System Default" VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </RadioButtons>
                    </StackPanel>

                    <!-- ======= Panel: Language ======= -->
                    <StackPanel x:Name="PanelLanguage" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="Language"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Choose your preferred display language."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />

                        <ComboBox x:Name="LanguageComboBox"
                                  SelectionChanged="OnLanguageSelectionChanged"
                                  MinWidth="220"
                                  Margin="0,8,0,0">
                            <ComboBoxItem Content="System Default" Tag="System" />
                            <ComboBoxItem Content="English" Tag="en-US" />
                            <ComboBoxItem Content="中文 (简体)" Tag="zh-CN" />
                        </ComboBox>
                        <TextBlock Text="* Language change requires app restart. / 语言切换需重启应用。"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   FontSize="12"
                                   FontStyle="Italic" />
                    </StackPanel>

                    <!-- ======= Panel: Environments ======= -->
                    <StackPanel x:Name="PanelEnvironments" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="Gateway Environments"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Manage your OpenClaw Gateway connections."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />

                        <!-- Environment list -->
                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="4"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ListView x:Name="EnvironmentList"
                                          Grid.Column="0"
                                          MinHeight="48"
                                          MaxHeight="150"
                                          SelectionMode="Single"
                                          SelectionChanged="OnEnvironmentSelectionChanged">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="13" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel Grid.Column="1" Orientation="Vertical"
                                            Spacing="2" Padding="4"
                                            VerticalAlignment="Top">
                                    <Button Click="OnAddClick"
                                            ToolTipService.ToolTip="Add" Padding="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="11" />
                                    </Button>
                                    <Button Click="OnRemoveClick"
                                            ToolTipService.ToolTip="Remove" Padding="6">
                                        <FontIcon Glyph="&#xE738;" FontSize="11" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Edit form -->
                        <TextBox x:Name="NameTextBox"
                                 Header="Environment Name"
                                 PlaceholderText="e.g. Production"
                                 Text="{x:Bind ViewModel.EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox x:Name="UrlTextBox"
                                 Header="Gateway URL"
                                 PlaceholderText="https://your-gateway.example.com"
                                 Text="{x:Bind ViewModel.EditUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="DefaultCheckBox"
                                      Content="Set as default"
                                      IsChecked="{x:Bind ViewModel.EditIsDefault, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <Button Content="Apply"
                                    Click="OnApplyClick"
                                    Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>

                        <InfoBar x:Name="ValidationInfoBar"
                                 IsOpen="False"
                                 Severity="Error"
                                 Title="Validation Error"
                                 Message="All environments must have a name and URL." />
                    </StackPanel>

                    <!-- ======= Panel: Developer Tools ======= -->
                    <StackPanel x:Name="PanelDevTools" Spacing="12" Visibility="Collapsed">
                        <TextBlock Text="Developer Tools"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Diagnostics and debugging utilities."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="13" />

                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Button HorizontalAlignment="Stretch" Click="OnRunDiagnosticsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                    <TextBlock Text="Run Diagnostics" />
                                </StackPanel>
                            </Button>
                            <Button HorizontalAlignment="Stretch" Click="OnViewLogsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" />
                                    <TextBlock Text="View Logs" />
                                </StackPanel>
                            </Button>
                            <Button HorizontalAlignment="Stretch" Click="OnDevToolsClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEC7A;" FontSize="14" />
                                    <TextBlock Text="Open DevTools" />
                                </StackPanel>
                            </Button>
                            <Button HorizontalAlignment="Stretch" Click="OnClearSessionClick">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    <TextBlock Text="Clear Session" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- =========================================================== -->
        <!-- BOTTOM BUTTON BAR                                           -->
        <!-- =========================================================== -->
        <Border Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Content="Save"
                        Click="OnSaveClick"
                        Style="{StaticResource AccentButtonStyle}"
                        MinWidth="80" />
                <Button Content="Cancel"
                        Click="OnCancelClick"
                        MinWidth="80" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
