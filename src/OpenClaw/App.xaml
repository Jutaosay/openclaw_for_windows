<Application
    x:Class="OpenClaw.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClaw">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Application-wide color resources -->
            <SolidColorBrush x:Key="StatusConnectedBrush" Color="#FF0EA5E9" />
            <SolidColorBrush x:Key="StatusReconnectingBrush" Color="#FFF59E0B" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#FFEF4444" />
            <SolidColorBrush x:Key="StatusOfflineBrush" Color="#FF6B7280" />

            <!-- Success/Accent colors -->
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF22C55E" />

            <!-- Subtle button style: transparent background, shows hover/press states -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
            </Style>

            <!-- Subtle style for DropDownButton (not a subclass of Button) -->
            <Style x:Key="SubtleDropDownButtonStyle" TargetType="DropDownButton">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
            </Style>

            <Style x:Key="ThemeSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="MinWidth" Value="28" />
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
