# Default to Git's text detection for files not listed below.
* text=auto

# Repository metadata
.gitattributes text eol=lf
.gitignore text eol=lf

# .NET / WinUI source and project files
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=crlf

# App manifests, resources, and configuration
*.manifest text eol=lf
*.appxmanifest text eol=lf
*.resw text eol=lf
*.config text eol=lf
*.xml text eol=lf
*.json text eol=lf

# Documentation and web artifacts
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Scripts
*.ps1 text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Native sources, if added later.
*.cpp text eol=lf
*.h text eol=lf

# Binary assets and packages
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.webp binary
*.pfx binary
*.snk binary
*.dll binary
*.exe binary
*.appx binary
*.appxbundle binary
*.msix binary
*.msixbundle binary
*.nupkg binary
*.snupkg binary
